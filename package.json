{
  "name": "order-tracking",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "api": "json-server db.json5 --port 3004",
    "dev": "next dev",
    "build": "next build",
    "start": "concurrently -k -s first -n app,api \"next dev\" \"npm run api\"",
    "lint": "eslint",
    "format": "prettier --write .",
    "test:integration": "playwright test --ui",
    "test:integration:headless": "playwright test"
  },
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10.9.8"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "json-server": "^1.0.0-beta.15",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/cypress": "^10.1.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4"
  }
}
